{
  "compilerOptions": {
    "target": "ES2022",
    "noImplicitAny": true,
    "module": "ES2022",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "vitest.config.integration.ts",
    "vitest.config.unit.ts"
  ],
  "exclude": ["node_modules"]
}
